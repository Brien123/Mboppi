# Views
msgid "User registered successfully. OTP sent to your email."
msgstr "Utilisateur enregistré avec succès. Le code OTP a été envoyé à votre e-mail."

msgid "User with this email does not exist."
msgstr "L'utilisateur avec cet e-mail n'existe pas."

msgid "OTP sent to your email."
msgstr "Code OTP envoyé à votre e-mail."

msgid "OTP has expired. Please request a new one."
msgstr "Le code OTP a expiré. Veuillez en demander un nouveau."

msgid "Email verified successfully. You can now login."
msgstr "E-mail vérifié avec succès. Vous pouvez maintenant vous connecter."

msgid "Invalid OTP or email."
msgstr "Code OTP ou e-mail invalide."

msgid "Your email is not verified. Please verify your email first."
msgstr "Votre e-mail n'est pas vérifié. Veuillez d'abord vérifier votre e-mail."

msgid "Login successful."
msgstr "Connexion réussie."

# Serializers
msgid "A user with this email already exists."
msgstr "Un utilisateur avec cet e-mail existe déjà."

msgid "Email and password are required."
msgstr "L'e-mail et le mot de passe sont requis."

msgid "Invalid email or password."
msgstr "E-mail ou mot de passe invalide."

